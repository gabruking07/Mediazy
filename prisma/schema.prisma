generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String    @unique
  username      String?   @unique
  emailVerified DateTime?
  image         String?
  bio           String?
  country       String?
  website       String?
  passwordHash  String?
  accounts      Account[]
  sessions      Session[]
  favorites     Favorite[]
  recentTools   RecentTool[]
  xpTransactions XPTransaction[]
  coinTransactions CoinTransaction[]
  achievements  UserAchievement[]
  dailyRewards  DailyRewardClaim[]
  dailyQuests   UserDailyQuest[]
  notifications Notification[]
  activities    RecentActivity[]
  statistics    UserStatistics?
  settings      UserSettings?
  uploadedFiles UploadedFile[]
  shareLinks    ShareLink[]
  shortLinks    ShortLink[]
  bioPage       BioPage?
  notes         Note[]
  pastes        Paste[]
  linkEvents    LinkEvent[]
  followers     Follow[]  @relation("following")
  following     Follow[]  @relation("follower")
  role          UserRole  @default(USER)
  plan          PremiumPlan @default(FREE)
  storageLimitBytes BigInt @default(1073741824)
  uploadLimitBytes  BigInt @default(16777216)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Favorite {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  toolSlug  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, toolSlug])
}

model RecentTool {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  toolSlug  String
  usedAt    DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, toolSlug])
}

model XPTransaction {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  amount    Int
  action    XPAction
  source    String?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model CoinTransaction {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  userId    String     @db.ObjectId
  amount    Int
  type      CoinAction
  source    String?
  metadata  Json?
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Achievement {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  slug        String   @unique
  name        String
  description String
  xpReward    Int      @default(0)
  coinReward  Int      @default(0)
  badge       String?
  createdAt   DateTime @default(now())
  users       UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  userId        String      @db.ObjectId
  achievementId String      @db.ObjectId
  progress      Int         @default(0)
  target        Int         @default(1)
  unlockedAt    DateTime?
  createdAt     DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId, unlockedAt])
}

model DailyRewardClaim {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  userId    String      @db.ObjectId
  day       Int
  reward    RewardType
  amount    Int
  claimDate DateTime
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, claimDate])
  @@index([userId, createdAt])
}

model DailyQuest {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  slug        String   @unique
  title       String
  description String
  target      Int
  xpReward    Int
  coinReward  Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  users       UserDailyQuest[]
}

model UserDailyQuest {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  userId      String     @db.ObjectId
  questId     String     @db.ObjectId
  progress    Int        @default(0)
  completedAt DateTime?
  questDate   DateTime
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  quest       DailyQuest @relation(fields: [questId], references: [id], onDelete: Cascade)

  @@unique([userId, questId, questDate])
  @@index([userId, questDate])
}

model Notification {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  userId    String           @db.ObjectId
  type      NotificationType
  title     String
  message   String
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

model RecentActivity {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  userId    String       @db.ObjectId
  type      ActivityType
  label     String
  metadata  Json?
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model UserStatistics {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  userId             String   @unique @db.ObjectId
  toolsUsed          Int      @default(0)
  imagesConverted    Int      @default(0)
  pdfFilesProcessed  Int      @default(0)
  qrGenerated        Int      @default(0)
  timeSavedSeconds   Int      @default(0)
  storageSavedBytes  Int      @default(0)
  longestStreak      Int      @default(0)
  currentStreak      Int      @default(0)
  lastLoginRewardAt  DateTime?
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Follow {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  followerId  String   @db.ObjectId
  followingId String   @db.ObjectId
  createdAt   DateTime @default(now())
  follower    User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
}

model UserSettings {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  userId              String   @unique @db.ObjectId
  theme               String   @default("system")
  emailNotifications  Boolean  @default(true)
  productUpdates      Boolean  @default(true)
  securityAlerts      Boolean  @default(true)
  twoFactorEnabled    Boolean  @default(false)
  defaultFileExpiryDays Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UploadedFile {
  id           String             @id @default(auto()) @map("_id") @db.ObjectId
  ownerId      String             @db.ObjectId
  name         String
  key          String?
  url          String
  mimeType     String
  sizeBytes    BigInt
  passwordHash String?
  expiresAt    DateTime?
  status       UploadedFileStatus @default(ACTIVE)
  downloads    Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  owner        User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  shareLinks   ShareLink[]
  events       LinkEvent[]

  @@index([ownerId, createdAt])
  @@index([status, expiresAt])
}

model ShareLink {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  ownerId       String          @db.ObjectId
  fileId        String          @db.ObjectId
  token         String          @unique
  access        ShareLinkAccess @default(PUBLIC)
  passwordHash  String?
  expiresAt     DateTime?
  maxDownloads  Int?
  downloadCount Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  owner         User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  file          UploadedFile    @relation(fields: [fileId], references: [id], onDelete: Cascade)
  events        LinkEvent[]

  @@index([ownerId, createdAt])
  @@index([fileId])
  @@index([expiresAt])
}

model ShortLink {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  ownerId     String      @db.ObjectId
  slug        String      @unique
  destination String
  title       String?
  clicks      Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  owner       User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  events      LinkEvent[]

  @@index([ownerId, createdAt])
}

model BioPage {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  ownerId   String    @unique @db.ObjectId
  slug      String    @unique
  title     String
  bio       String?
  avatarUrl String?
  theme     String    @default("mediazy")
  links     BioLink[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  owner     User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model BioLink {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  pageId    String   @db.ObjectId
  label     String
  url       String
  position  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  page      BioPage  @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, position])
}

model Note {
  id        String                 @id @default(auto()) @map("_id") @db.ObjectId
  ownerId   String                 @db.ObjectId
  title     String
  content   String
  status    ProductivityItemStatus @default(ACTIVE)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  owner     User                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, updatedAt])
}

model Paste {
  id          String                 @id @default(auto()) @map("_id") @db.ObjectId
  ownerId     String                 @db.ObjectId
  slug        String                 @unique
  title       String
  content     String
  language    String?
  visibility  String                 @default("private")
  expiresAt   DateTime?
  status      ProductivityItemStatus @default(ACTIVE)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  owner       User                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, createdAt])
  @@index([expiresAt])
}

model LinkEvent {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  ownerId     String?     @db.ObjectId
  fileId      String?     @db.ObjectId
  shareLinkId String?     @db.ObjectId
  shortLinkId String?     @db.ObjectId
  type        String
  ipHash      String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime    @default(now())
  owner       User?       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  file        UploadedFile? @relation(fields: [fileId], references: [id], onDelete: Cascade)
  shareLink   ShareLink?  @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
  shortLink   ShortLink?  @relation(fields: [shortLinkId], references: [id], onDelete: Cascade)

  @@index([ownerId, createdAt])
  @@index([shareLinkId, createdAt])
  @@index([shortLinkId, createdAt])
}

enum UserRole {
  USER
  ADMIN
}

enum PremiumPlan {
  FREE
  PRO
  BUSINESS
}

enum UploadedFileStatus {
  ACTIVE
  EXPIRED
  FLAGGED
  DELETED
}

enum ShareLinkAccess {
  PUBLIC
  PASSWORD
}

enum ProductivityItemStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum XPAction {
  LOGIN
  USE_TOOL
  SHARE_TOOL
  COMPLETE_DAILY_QUEST
  INVITE_FRIEND
  WIN_MINI_GAME
  UNLOCK_ACHIEVEMENT
}

enum CoinAction {
  DAILY_LOGIN
  DAILY_QUEST
  ACHIEVEMENT
  MINI_GAME
  INVITE
  SPECIAL_EVENT
  ADJUSTMENT
}

enum RewardType {
  XP
  COINS
  PREMIUM_TRIAL
  BADGE
  THEME
}

enum NotificationType {
  ACHIEVEMENT_UNLOCKED
  COINS_EARNED
  QUEST_COMPLETED
  LEVEL_UP
  WEEKLY_SUMMARY
  FRIEND_REQUEST
  SYSTEM_UPDATE
}

enum ActivityType {
  LOGIN
  TOOL_USED
  QUEST_COMPLETED
  ACHIEVEMENT_UNLOCKED
  LEVEL_UP
  COINS_EARNED
}
