NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/mediazy
CLIENT_URL=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:5000
JWT_SECRET=change-this-long-random-secret
AUTH_TOKEN_TTL_HOURS=24
DAILY_DOWNLOAD_LIMIT=20
DOWNLOAD_TTL_MINUTES=10
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX=60
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=Mediazy <noreply@mediazy.local>

# yt-dlp runtime tweaks
YTDLP_FORCE_IPV4=true
YTDLP_SOCKET_TIMEOUT_SECONDS=30
YTDLP_RETRIES=5
YTDLP_FRAGMENT_RETRIES=5
YTDLP_EXTRACTOR_RETRIES=3
YTDLP_FILE_ACCESS_RETRIES=3
YTDLP_CONCURRENT_FRAGMENTS=4
YTDLP_SLEEP_REQUESTS_SECONDS=
YTDLP_SLEEP_INTERVAL_SECONDS=
YTDLP_MAX_SLEEP_INTERVAL_SECONDS=
YTDLP_PROXY=
YTDLP_USER_AGENT=
YTDLP_COOKIES_PATH=
YTDLP_COOKIES_BASE64=
